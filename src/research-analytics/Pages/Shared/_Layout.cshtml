<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FX Research Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <!-- Top bar -->
    <div class="topbar">
        <div class="container-xl d-flex justify-content-between align-items-center">
            <div class="topbar-date">@DateTime.UtcNow.ToString("dddd, MMMM dd, yyyy") &nbsp;|&nbsp; UTC</div>
            <div class="topbar-links">
                <a href="/Account/Login" class="text-white text-decoration-none small me-3">
                    <i class="fa-regular fa-circle-user" style="margin-right:3px"></i>Login
                </a>
                <a href="/Admin/Login" class="text-white text-decoration-none small">Admin</a>
            </div>
        </div>
    </div>

    <!-- Main header -->
    <header class="site-header">
        <div class="container-xl">
            <div class="d-flex align-items-center justify-content-between py-3">
                <a class="site-logo text-decoration-none" asp-page="/Index">
                    <span class="logo-fx">FX</span><span class="logo-research">Research</span>
                </a>
                <div class="header-tagline d-none d-md-block">
                    Commodities &amp; Global Markets &mdash; FX Research
                </div>
                <button class="navbar-toggler d-md-none" type="button" id="mobileMenuToggle">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </div>
    </header>

    <!-- Category nav -->
    <nav class="category-nav">
        <div class="container-xl">
            <div class="category-nav-inner">
                <a class="cat-link @(ViewData["Category"]?.ToString() == "All" || ViewData["Category"] == null ? "active" : "")" href="/?category=All">All</a>
                <a class="cat-link @(ViewData["Category"]?.ToString() == "AUD/USD" ? "active" : "")" href="/?category=AUD%2FUSD">AUD/USD</a>
                <a class="cat-link @(ViewData["Category"]?.ToString() == "AUD/CNH" ? "active" : "")" href="/?category=AUD%2FCNH">AUD/CNH</a>
                <a class="cat-link @(ViewData["Category"]?.ToString() == "AUD/GBP" ? "active" : "")" href="/?category=AUD%2FGBP">AUD/GBP</a>
            </div>
        </div>
    </nav>

    <div class="container-xl main-content">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container-xl">
            <div class="footer-bottom">
                <span>&copy; @DateTime.UtcNow.Year FX Research Portal &mdash; For informational purposes only. Not financial advice.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/tracker.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Chat Widget -->
    <button id="chatkit-toggle" class="chatkit-float-btn" title="Ask Research Assistant">
        <i class="fa-solid fa-comments"></i>
    </button>
    <div id="chatkit-panel" class="chatkit-float-panel">
        <div class="chatkit-header">
            <span>FX Research Assistant</span>
        </div>
        <div id="chatkit-messages" class="chatkit-messages"></div>
        <div id="chatkit-prompts" class="chatkit-prompts">
            <button class="chatkit-prompt-btn" data-prompt="What is the current market outlook for AUD/USD?">Market outlook</button>
            <button class="chatkit-prompt-btn" data-prompt="What trading strategies work best for AUD/CNH?">Trading strategy</button>
            <button class="chatkit-prompt-btn" data-prompt="Provide a technical analysis for AUD/GBP.">Currency analysis</button>
        </div>
        <form id="chatkit-form" class="chatkit-input">
            <input id="chatkit-input" type="text" placeholder="Ask about market research..." autocomplete="off" />
            <button type="submit"><i class="fa-solid fa-paper-plane"></i></button>
        </form>
    </div>
    <script src="~/js/chat.js" asp-append-version="true"></script>
</body>
</html>
