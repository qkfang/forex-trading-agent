{
  "managedApiConnections": {},
  "serviceProviderConnections": {
    "AzureBlob": {
      "parameterValues": {
        "connectionString": "@appsetting('BLOB_CONNECTION_STRING')"
      },
      "serviceProvider": {
        "id": "/serviceProviders/AzureBlob"
      },
      "displayName": "AzureBlob"
    },
    "EventHub": {
      "parameterValues": {
        "fullyQualifiedNamespace": "@appsetting('EVENTHUB_FULLY_QUALIFIED_NAMESPACE')",
        "authProvider": {
          "Type": "ManagedServiceIdentity"
        }
      },
      "serviceProvider": {
        "id": "/serviceProviders/eventHub"
      },
      "displayName": "EventHub"
    }
  }
}
